# ── Database ────────────────────────────────────────────────
MARIADB_HOST=mariadb
MARIADB_PORT=3306
MARIADB_DB=utility_bills
MARIADB_USER=bills_user
MARIADB_PASSWORD=CHANGE_ME
MYSQL_ROOT_PASSWORD=CHANGE_ME

# ── Internal API key (server-to-server calls) ───────────────
API_SECRET_KEY=CHANGE_ME

# ── Android app auth: Google Sign-In, single-email allowlist ─
SESSION_SECRET=CHANGE_ME            # HS256 signing secret for session JWTs
GOOGLE_WEB_CLIENT_ID=               # OAuth *web* client ID (token audience)
ALLOWED_EMAILS=you@example.com      # comma-separated; only these may sign in

# ── Telegram notifications ──────────────────────────────────
TELEGRAM_BOT_TOKEN=CHANGE_ME
TELEGRAM_CHAT_ID=CHANGE_ME

# ── Misc ────────────────────────────────────────────────────
POLL_DAILY_TIME=09:00
DASHBOARD_BASE_URL=https://your-nas.example.com
